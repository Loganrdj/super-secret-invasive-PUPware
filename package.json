{
  "name": "Crazy-Invasive-Malware-BEWARE",
  "version": "1.0.0",
  "description": "Transparent desktop overlay where dogs occasionally wander across and sniff the camera",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.logan.dogoverlay",
    "productName": "Dog Overlay",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!node_modules/.cache/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment",
      "icon": "/build/doglogo.icns"
    }
  }
}